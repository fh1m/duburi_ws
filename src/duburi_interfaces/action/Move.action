# Goal — one field per command type, unused fields are zero/empty
string  cmd          # arm | disarm | set_mode | stop | pause |
                     # move_forward | move_back | move_left | move_right |
                     # move_forward_dist | move_lateral_dist |
                     # yaw_left | yaw_right | arc | set_depth |
                     # lock_heading | unlock_heading | dvl_connect |
                     # vision_align_3d | vision_align_yaw | vision_align_lat |
                     # vision_align_depth | vision_hold_distance | vision_acquire
float32 duration     # seconds  (move_*, arc, pause, vision_*)
float32 gain         # 0-100 %  (move_*, arc, vision_acquire drive level)
float32 target       # metres   (set_depth) or
                     # degrees  (yaw_*, lock_heading: 0=current heading)
string  target_name  # mode string  (set_mode) or
                     # drive verb   (vision_acquire: 'yaw_left'|'yaw_right'|'move_forward'|'arc')
float32 timeout      # max wait (all commands; lock_heading auto-releases)
float32 settle       # post-command neutral-hold seconds; 0 = axis-natural settle only
float32 yaw_rate_pct # signed -100..+100 percent yaw stick; `arc` and vision_acquire('arc')

# ---- DVL distance fields  (ignored by non-DVL commands) ----------
float32 distance_m     # target distance in metres (move_*_dist)
float32 dvl_tolerance  # stop when |error| <= this, metres (default 0.1)

# ---- vision_* fields  (ignored by every non-vision command) -----------
string  camera             # 'laptop' | 'sim_front' | 'forward' | 'downward'
string  target_class       # 'person' | 'gate' | ... ('' = first available)
string  axes               # CSV: any of 'yaw,lat,depth,forward'  (vision_align_3d)
float32 deadband           # |error| considered centered (normalized 0..1)
float32 kp_yaw             # gain on yaw axis        (pct per unit ex)
float32 kp_lat             # gain on lateral axis    (pct per unit ex)
float32 kp_depth           # gain on depth axis      (m per unit ey per tick)
float32 kp_forward         # gain on forward axis    (pct per unit h_frac error)
float32 target_bbox_h_frac # bbox height target as fraction of image height
bool    visual_pid         # false=P only; true=PI (anti-windup, v2 hook)
string  on_lost            # 'fail' (default) | 'hold'
float32 stale_after        # seconds; older detection considered lost
float32 depth_anchor_frac  # which vertical point on the bbox to centre (0=top, 0.5=centre, 1=bottom)
                           # 0.0 on wire = use ROS param (vision.depth_anchor_frac, default 0.5)
                           # Use 0.2 for tall objects (people, poles) to avoid depth stall
string  lock_mode          # '' or 'settle' (default) | 'follow' | 'pursue'
                           # follow = track until duration; pursue = approach until target_bbox_h_frac
string  distance_metric    # '' or 'height' (default) | 'area' | 'diagonal'
                           # area/diagonal are more robust for wide targets like gates
bool    tracking           # false (default) = use /detections; true = use /tracks (requires tracker_node)
---
# Result — axis-correct (set on the axis the command actually moves):
#   yaw_left / yaw_right :  final_value = final yaw [deg, 0..360]
#                           error_value = remaining heading error [deg, signed]
#   set_depth            :  final_value = final depth [m, negative below surface]
#                           error_value = |target - final| [m]
#   move_*               :  final_value = final depth [m]   (no axis odometry yet)
#                           error_value = 0.0
#   arc                  :  final_value = final yaw [deg, 0..360]
#                           error_value = heading drift vs expected [deg, signed]
#   lock_heading         :  final_value = locked target heading [deg, 0..360]
#                           error_value = 0.0
#   unlock_heading       :  final_value = current depth [m]
#                           error_value = 0.0
#   arm / disarm / stop  :  final_value = current depth [m]
#                           error_value = 0.0
#   vision_align_*       :  final_value = composite normalized error [0..1+]
#                           error_value = age of last detection [s] at exit
#   vision_hold_distance :  final_value = |target_bbox_h_frac - last h_frac|
#                           error_value = age of last detection [s]
#   vision_acquire       :  final_value = time-to-acquire [s] on success
#                           error_value = 0.0 on success, timeout on failure
bool    success
string  message
float32 final_value
float32 error_value
---
# Feedback — streamed at ~2.5 Hz while the goal is EXECUTING.
# current_value is depth (m); status_line is a human-readable one-liner.
string  phase        # e.g. "EXECUTING", "DONE"
float32 current_value
float32 error_value
string  status_line  # human-readable one-liner
